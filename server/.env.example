PORT=3001
HOST=0.0.0.0

# Docker Compose (repo root): published host port for the web UI; process in the container uses PORT=3001.
# OXIDIZED_PORT=3001
CLIENT_ORIGIN=http://localhost:5173
SQLITE_PATH=./data/oxidized.db

# RCON targets game processes in this container (default 127.0.0.1).
# LOCAL_GAME_HOST=127.0.0.1

# Per-server files: <dir-of-SQLITE>/instances/<id>/
# Shared Rust dedicated binaries (SteamCMD installs here):
# Shared Rust DS install (default: ./data/instances/_shared/rust-dedicated; legacy ./data/rust-dedicated still used if present)
# RUST_DS_INSTALL_DIR=./data/instances/_shared/rust-dedicated

# If players can’t reach you behind NAT / wrong IP in Steam, set your public IPv4 (optional)
# OXIDIZED_APP_PUBLICIP=203.0.113.50

# Local dev: skip Steam download and use a mock process for Start/Stop
# OXIDIZED_SKIP_STEAM_INSTALL=1

# Path to steamcmd.sh (Dockerfile installs to /opt/steamcmd/steamcmd.sh)
# STEAMCMD_SCRIPT=/opt/steamcmd/steamcmd.sh

# Manual Rust binary (skips Steam in the panel; still set RUST_DS_INSTALL_DIR for docs)
# OXIDIZED_RUSTDEDICATED_BIN=/path/to/RustDedicated
# Default cwd is the directory containing RustDedicated (required so Unity finds Bundles/). Override only if you understand the layout.
# OXIDIZED_RUSTDEDICATED_CWD=/path/to/rust-dedicated

# GitHub API (plugin catalog / installs). Optional: also configurable in the UI under Settings.
# OXIDIZED_GITHUB_TOKEN=ghp_...
# GITHUB_TOKEN=ghp_...

# Production / Docker: UI under server/static
# SERVE_STATIC=1
# TRUST_PROXY=1
# CORS_ORIGIN=https://oxidized.example.com
